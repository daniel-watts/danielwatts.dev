---
import { site, hero } from "../data/site";
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="eyebrow">{site.role} · {site.location}</p>
      <h1 id="hero-heading">{hero.headline}</h1>
      <p class="lead">{hero.subhead}</p>
      <div class="cta-group">
        <a class="btn btn-primary" href={hero.primaryCta.href}>
          {hero.primaryCta.label}
        </a>
        <a class="btn btn-secondary" href={hero.secondaryCta.href}>
          {hero.secondaryCta.label}
        </a>
      </div>
    </div>
    <img
      class="hero-photo"
      src="/images/daniel.jpg"
      alt={`Portrait of ${site.name}`}
      width="640"
      height="640"
      fetchpriority="high"
      decoding="async"
    />
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(4rem, 12vw, 8rem);
    background:
      radial-gradient(
        60rem 30rem at 80% -10%,
        color-mix(in srgb, var(--color-accent) 12%, transparent),
        transparent
      );
  }
  .hero-inner {
    display: flex;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }
  .hero-text {
    flex: 1;
    min-width: 0;
  }
  .hero-photo {
    flex-shrink: 0;
    width: clamp(9rem, 22vw, 16rem);
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid var(--color-surface);
    box-shadow: var(--shadow);
  }
  @media (max-width: 640px) {
    .hero-inner {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
  }
  .lead {
    max-width: 42rem;
    font-size: clamp(1.0625rem, 2.5vw, 1.375rem);
    color: var(--color-text-muted);
    margin-top: 1.25rem;
  }
  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>

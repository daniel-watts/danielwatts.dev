---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p>© {year} {site.name}. All rights reserved.</p>
    <p>
      Built with <a href="https://astro.build" rel="noopener noreferrer">Astro</a>.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: 2rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .footer p {
    font-size: 0.875rem;
    margin: 0;
  }
</style>

---
interface Project {
  title: string;
  category?: string;
  date?: string;
  image?: string;
  description?: string;
  tech?: string[];
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<li class="card">
  {
    project.image && (
      <img
        class="card-image"
        src={project.image}
        alt={`Screenshot of ${project.title}`}
        loading="lazy"
        decoding="async"
        width="640"
        height="400"
      />
    )
  }
  <div class="card-body">
    <div class="card-head">
      <h3 class="card-title">{project.title}</h3>
      {project.date && <p class="card-date">{project.date}</p>}
    </div>
    {project.category && <p class="card-category">{project.category}</p>}
    {project.description && <p class="card-desc">{project.description}</p>}
    {
      project.tech && project.tech.length > 0 && (
        <ul class="tags" aria-label="Technologies used">
          {project.tech.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</li>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .card-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.25rem 1rem;
  }
  .card-title {
    margin: 0;
  }
  .card-date {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    white-space: nowrap;
  }
  .card-category {
    margin: 0.35rem 0 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .card-desc {
    margin: 0.75rem 0 0;
    flex: 1;
  }
  .tags {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }
</style>
